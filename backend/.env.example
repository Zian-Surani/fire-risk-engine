# Backend runtime environment (copy to .env and customize)
# Host/port
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend origin (CORS)
FRONTEND_ORIGIN=http://localhost:3000

# Databricks (optional)
# If using Databricks, either set DATABRICKS_TOKEN or use metadata service.
DATABRICKS_HOST=
DATABRICKS_AUTH_TYPE=
DATABRICKS_METADATA_SERVICE_URL=
DATABRICKS_TOKEN=
DATABRICKS_WAREHOUSE_ID=
# Unity Catalog catalog/schema where Silver/Gold tables exist (not hive_metastore unless enabled)
DATABRICKS_CATALOG=workspace
DATABRICKS_SCHEMA=default

# Refresh intervals (seconds)
REFRESH_INTERVAL_SECONDS=5
RISK_REFRESH_INTERVAL_SECONDS=60
AI_REFRESH_INTERVAL_SECONDS=60
WEBSOCKET_PING_INTERVAL_SECONDS=15

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ENABLED=false

# Gemini (Google AI)
GEMINI_API_KEY=
# Current API model id (legacy names like gemini-1.5-flash often 404 on v1)
GEMINI_MODEL=gemini-2.0-flash
GEMINI_ENABLED=true
# Cache successful responses (seconds); higher = fewer API calls / less quota use
GEMINI_CACHE_TTL_SECONDS=900
# After 429 / free-tier quota hit, pause Gemini calls for this long (seconds)
GEMINI_RATE_LIMIT_COOLDOWN_SECONDS=300